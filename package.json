{
  "name": "pia",
  "version": "0.1.0",
  "description": "PIA — Personal Integrated Applications. A standalone web terminal.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:engine": "tsc -p tsconfig.engine.json && node scripts/build-engine.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.5"
  }
}
